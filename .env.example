# ===== 应用配置 =====
APP_NAME=resume-analyzer
APP_VERSION=0.1.0
LOG_LEVEL=INFO
ENVIRONMENT=development

# ===== LLM 配置（小米 MiMo via Novita） =====
# 申请 key：https://novita.ai/
MIMO_API_KEY=your-novita-api-key-here
MIMO_BASE_URL=https://api.novita.ai/v3/openai
MIMO_MODEL=xiaomimimo/mimo-v2-flash
MIMO_TIMEOUT=30
MIMO_MAX_RETRIES=3

# ===== 缓存配置 =====
# memory：默认，单实例零依赖
# redis：跨实例共享，需配 REDIS_URL
CACHE_BACKEND=memory
CACHE_DEFAULT_TTL=86400
REDIS_URL=

# ===== 上传限制 =====
MAX_UPLOAD_SIZE_MB=10

# ===== 评分权重 =====
HEURISTIC_WEIGHT=0.6
LLM_WEIGHT=0.4
SKILL_WEIGHT=0.5
EXPERIENCE_WEIGHT=0.3
EDUCATION_WEIGHT=0.2

# ===== CORS =====
CORS_ORIGINS=*
