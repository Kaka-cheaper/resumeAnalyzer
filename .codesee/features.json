    { "from": "f-cache", "to": "f-pdf-parse", "kind": "depends_on", "note": "解析前查询缓存" },
    { "from": "f-cache", "to": "f-match-score", "kind": "depends_on", "note": "评分前查询缓存" },
    { "from": "f-deploy", "to": "f-upload-pdf", "kind": "depends_on", "note": "后端部署后接口可用" },
    { "from": "f-deploy", "to": "f-frontend-upload", "kind": "depends_on", "note": "前端部署后用户可访问" }
  ],
  "epic_flow": [
    { "from": "frontend", "to": "upload", "kind": "next", "note": "用户从前端发起上传" },
    { "from": "upload", "to": "parse", "kind": "next", "note": "上传完成后进入解析" },
    { "from": "parse", "to": "extract", "kind": "next", "note": "清洗文本后抽取信息" },
    { "from": "extract", "to": "scoring", "kind": "next", "note": "信息齐备后进行岗位匹配" },
    { "from": "scoring", "to": "frontend", "kind": "next", "note": "评分结果回到前端展示" },
    { "from": "upload", "to": "infra", "kind": "depends_on", "note": "依赖 Serverless 与缓存底座" },
    { "from": "scoring", "to": "infra", "kind": "depends_on", "note": "依赖缓存避免重复计算" }
  ]
}
